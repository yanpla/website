---
interface Props {
  href: string;
  title: string;
  subtitle: string;
  hoverTitle?: string;
  hoverSubtitle?: string;
}

const { href, title, subtitle, hoverTitle, hoverSubtitle } = Astro.props;

const hasHover = !!(
  hoverTitle ||
  hoverSubtitle ||
  Astro.slots.has("hover-icon")
);
---

<a class="m-1" href={href} target="_blank">
  <div
    class="inline-flex items-center justify-center rounded-2xl [corner-shape:squircle] border bg-background shadow-sm hover:bg-accent hover:text-accent-foreground w-72 h-32 relative group overflow-hidden"
  >
    {/* Front Side */}
    <div
      class:list={[
        "flex flex-row items-center w-full px-6 justify-between absolute transition-all",
        { "group-hover:-translate-y-48": hasHover },
      ]}
    >
      <div class="mr-2 w-12 h-12 flex items-center justify-center text-current">
        <slot name="icon" />
      </div>
      <div class="flex flex-col text-left">
        <h2 class="text-xl font-bold">{title}</h2>
        <p>{subtitle}</p>
      </div>
    </div>

    {/* Back Side */}
    {
      hasHover && (
        <div class="flex flex-row items-center w-full px-6 justify-between absolute group-hover:translate-y-0 translate-y-48 transition-all">
          <div class="mr-2 w-12 h-12 flex items-center justify-center text-current">
            <slot name="hover-icon" />
          </div>
          <div class="flex flex-col text-center">
            {hoverTitle && <h2 class="text-xl font-bold">{hoverTitle}</h2>}
            {hoverSubtitle && <p>{hoverSubtitle}</p>}
          </div>
        </div>
      )
    }
  </div>
</a>

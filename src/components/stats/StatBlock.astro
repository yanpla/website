---
/**
 * A stat panel headed by a status dot, a primary label, an optional small
 * figure, and a right-aligned monospace context label. The body slot holds
 * whatever the panel visualizes (progress bar, totals row, …).
 */
import StatusDot from "@/components/ui/StatusDot.astro";

interface Props {
  color: string;
  label: string;
  sublabel?: string;
  meta?: string;
  /** Entrance animation delay in seconds. */
  delay?: number;
}

const { color, label, sublabel, meta, delay = 0 } = Astro.props;
---

<div
  class="flex flex-col space-y-3 animate-entrance"
  style={`animation-delay: ${delay}s;`}
>
  <div class="flex items-center justify-between">
    <div class="flex items-center space-x-2">
      <StatusDot color={color} />
      <span class="text-sm font-medium">{label}</span>
      {
        sublabel && (
          <span class="text-xs text-muted-foreground tabular-nums">
            {sublabel}
          </span>
        )
      }
    </div>
    {
      meta && (
        <span class="text-xs text-muted-foreground font-mono tracking-wide">
          {meta}
        </span>
      )
    }
  </div>
  <slot />
</div>

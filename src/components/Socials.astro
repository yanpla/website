---
export const prerender = false;

import SocialCard from "./SocialCard.astro";
import DiscordIcon from "../assets/discord.svg";
import GithubIcon from "../assets/github.svg";
import Branch from "../assets/branch.svg";

const GITHUB_TOKEN = import.meta.env.GITHUB_TOKEN;
const username = "yanpla";
const userId = "287291530685841409";

// 1. Fetch GitHub data with Token for higher rate limits
const headers = { Authorization: `token ${GITHUB_TOKEN}` };

const [githubUserResponse, commitResponse, discordUserResponse] =
  await Promise.all([
    fetch(`https://api.github.com/users/${username}`, { headers }),
    fetch(`https://api.github.com/search/commits?q=author:${username}`, {
      headers: { ...headers, Accept: "application/vnd.github.cloak-preview" },
    }),
    fetch(`https://api.lanyard.rest/v1/users/${userId}`),
  ]);

const githubUserData = await githubUserResponse.json();
const commitData = await commitResponse.json();
const discordUserData = await discordUserResponse.json();

const repoCount = githubUserData.public_repos || 0;
const totalCommits = commitData.total_count || 0;

const commitDisplay =
  totalCommits >= 1000 ? `${(totalCommits / 1000).toFixed(1)}k+` : totalCommits;

// 2. Discord Status Logic
type DiscordStatus = "online" | "idle" | "dnd" | "offline" | "streaming";
interface DiscordActivity {
  type: number;
  name: string;
}
const discordStatus: DiscordStatus =
  discordUserData.data?.discord_status || "offline";
const statusColors: Record<DiscordStatus, string> = {
  online: "#23a55a",
  idle: "#f0b232",
  dnd: "#f23f43",
  offline: "#80848e",
  streaming: "#593695",
};
const currentHex = statusColors[discordStatus] || statusColors.offline;

const activity = (discordUserData.data?.activities as DiscordActivity[] | undefined)?.find(
  (a: DiscordActivity) => a.type === 0
);
---

<div
  class="flex flex-col-reverse md:flex-row-reverse md:justify-normal items-center"
>
  <SocialCard
    href={`https://discord.com/users/${userId}`}
    title="Discord"
    subtitle="@yanpla"
    hoverTitle={`Status: ${discordStatus.charAt(0).toUpperCase() + discordStatus.slice(1)}`}
    hoverSubtitle={activity
      ? `Playing ${activity.name}`
      : "No current activity"}
  >
    <DiscordIcon slot="icon" />
    <div
      slot="hover-icon"
      style={{ backgroundColor: currentHex }}
      class="w-4 h-4 rounded-full shadow-[0_0_10px_rgba(0,0,0,0.2)]"
      style={{ boxShadow: `0 0 12px ${currentHex}` }}
    >
    </div>
  </SocialCard>

  <SocialCard
    href={`https://github.com/${username}`}
    title="GitHub"
    subtitle="@yanpla"
    hoverTitle={`${repoCount} repositories`}
    hoverSubtitle={`and ${commitDisplay} commits`}
  >
    <GithubIcon slot="icon" />
    <Branch slot="hover-icon" />
  </SocialCard>
</div>

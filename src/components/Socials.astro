---
import SocialCard from "@/components/ui/SocialCard.astro";
import DiscordIcon from "@/assets/discord.svg";
import GithubIcon from "@/assets/github.svg";
import Branch from "@/assets/branch.svg";
import { DISCORD, GITHUB } from "@/consts";
import { getDiscordPresence, type DiscordStatus } from "@/lib/discord";
import { getGithubProfileStats } from "@/lib/github";

const [github, discord] = await Promise.all([
  getGithubProfileStats(),
  getDiscordPresence(),
]);

const { repoCount = 0, totalCommits = 0 } = github.data ?? {};
const commitDisplay =
  totalCommits >= 1000
    ? `${(totalCommits / 1000).toFixed(1)}k+`
    : `${totalCommits}`;

const statusColors: Record<DiscordStatus, string> = {
  online: "#23a55a",
  idle: "#f0b232",
  dnd: "#f23f43",
  offline: "#80848e",
  streaming: "#593695",
};
const statusColor = statusColors[discord.status] ?? statusColors.offline;
const statusDisplay =
  discord.status.charAt(0).toUpperCase() + discord.status.slice(1);
---

<div class="flex flex-col md:flex-row-reverse md:justify-normal items-center gap-2">
  <SocialCard
    href={`https://discord.com/users/${DISCORD.userId}`}
    title="Discord"
    subtitle={`@${DISCORD.username}`}
    hoverTitle={`Status: ${statusDisplay}`}
    hoverSubtitle={discord.playing ? `Playing ${discord.playing}` : "No current activity"}
  >
    <DiscordIcon slot="icon" />
    <div
      slot="hover-icon"
      class="w-3.5 h-3.5 rounded-full"
      style={{ backgroundColor: statusColor, boxShadow: `0 0 6px ${statusColor}` }}
    />
  </SocialCard>

  <SocialCard
    href={`https://github.com/${GITHUB.username}`}
    title="GitHub"
    subtitle={`@${GITHUB.username}`}
    hoverTitle={`${repoCount} repositories`}
    hoverSubtitle={`and ${commitDisplay} commits`}
  >
    <GithubIcon slot="icon" />
    <Branch slot="hover-icon" />
  </SocialCard>
</div>

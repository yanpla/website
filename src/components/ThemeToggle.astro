---

<button
  id="theme-toggle"
  class="p-2 rounded-lg hover:bg-accent hover:text-accent-foreground transition-colors duration-200 cursor-pointer"
  aria-label="Toggle theme"
>
  <svg id="sun-icon" class="w-5 h-5 hidden theme-icon-enter" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
  </svg>
  <svg id="moon-icon" class="w-5 h-5 hidden theme-icon-enter" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
  </svg>
</button>

<script is:inline>
  (function() {
    var html = document.documentElement;
    var sun = document.getElementById('sun-icon');
    var moon = document.getElementById('moon-icon');
    var btn = document.getElementById('theme-toggle');

    function update() {
      var dark = html.classList.contains('dark');
      sun.classList.toggle('hidden', !dark);
      moon.classList.toggle('hidden', dark);
    }

    function retriggerAnimation() {
      [sun, moon].forEach(function(el) {
        el.classList.remove('theme-icon-enter');
        void el.offsetWidth;
        el.classList.add('theme-icon-enter');
      });
    }

    update();

    btn.addEventListener('click', function() {
      html.classList.toggle('dark');
      localStorage.setItem('theme', html.classList.contains('dark') ? 'dark' : 'light');
      retriggerAnimation();
      update();
    });
  })();
</script>

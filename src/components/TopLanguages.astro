---
export const prerender = false;

interface Language {
  name: string;
  color: string;
  size: number;
}

interface Repository {
  name: string;
  languages?: {
    edges: {
      size: number;
      node: {
        color: string;
        name: string;
      };
    }[];
  };
}

const GITHUB_TOKEN = import.meta.env.GITHUB_TOKEN;
const username = "yanpla";

let sortedLangs: Language[] = [];
let totalSize = 0;
let error: string | null = null;

if (!GITHUB_TOKEN) {
  error = "GitHub token not configured";
} else {
  try {
    const query = `
      query userInfo($login: String!) {
        user(login: $login) {
          repositories(ownerAffiliations: [OWNER, COLLABORATOR], isFork: false, first: 100, privacy: PUBLIC) {
            nodes {
              name
              languages(first: 10, orderBy: {field: SIZE, direction: DESC}) {
                edges {
                  size
                  node {
                    color
                    name
                  }
                }
              }
            }
          }
        }
      }
    `;

    const response = await fetch("https://api.github.com/graphql", {
      method: "POST",
      headers: {
        Authorization: `Bearer ${GITHUB_TOKEN}`,
        "Content-Type": "application/json",
      },
      body: JSON.stringify({ query, variables: { login: username } }),
    });

    if (!response.ok) {
      throw new Error(`HTTP error! status: ${response.status}`);
    }

    const json = await response.json();

    if (json.errors) {
      throw new Error(json.errors[0]?.message || "GraphQL error");
    }

    const excludeList = ["remnantsoflight"];
    const repos =
      (
        json.data?.user?.repositories?.nodes as Repository[] | undefined
      )?.filter((repo) => !excludeList.includes(repo.name)) ?? [];

    const langMap = repos
      .filter((repo) => (repo.languages?.edges?.length ?? 0) > 0)
      .reduce<Record<string, Language>>((acc, repo) => {
        repo.languages!.edges.forEach((edge) => {
          const { name, color } = edge.node;
          if (!acc[name]) {
            acc[name] = { name, color, size: 0 };
          }
          acc[name].size += edge.size;
        });
        return acc;
      }, {});

    sortedLangs = Object.values(langMap)
      .sort((a, b) => b.size - a.size)
      .slice(0, 6);

    totalSize = sortedLangs.reduce((acc, curr) => acc + curr.size, 0);
  } catch (e) {
    error = e instanceof Error ? e.message : "Failed to fetch languages";
  }
}
---

<section>
  <div class="flex flex-col space-y-5">
    <div class="flex justify-between items-baseline">
      <h2 class="text-2xl font-bold tracking-tight">top languages</h2>
      <span class="text-xs text-muted-foreground font-mono tracking-wide">based on github bytes</span>
    </div>

    {
      error ? (
        <div class="text-sm text-muted-foreground animate-entrance">failed to load: {error}</div>
      ) : sortedLangs.length === 0 ? (
        <div class="text-sm text-muted-foreground animate-entrance">no languages found</div>
      ) : (
        <>
          {/* Progress Bar */}
          <div class="flex w-full h-2.5 overflow-hidden rounded-full bg-muted">
            <div class="flex w-full h-full animate-bar-fill">
              {sortedLangs.map((lang) => (
                <div
                  style={{
                    width: `${(lang.size / totalSize) * 100}%`,
                    backgroundColor: lang.color,
                  }}
                  class="h-full transition-opacity duration-200 hover:opacity-75"
                  title={`${lang.name} ${Math.round((lang.size / totalSize) * 100)}%`}
                />
              ))}
            </div>
          </div>

          {/* Legend */}
          <div class="grid grid-cols-2 md:grid-cols-3 gap-y-2.5 gap-x-4">
            {sortedLangs.map((lang, i) => (
              <div
                class="flex items-center space-x-2 animate-entrance"
                style={`animation-delay: ${0.1 + i * 0.05}s;`}
              >
                <div
                  class="w-2.5 h-2.5 rounded-full flex-shrink-0"
                  style={{ backgroundColor: lang.color }}
                />
                <span class="text-sm font-medium truncate">{lang.name}</span>
                <span class="text-xs text-muted-foreground tabular-nums">
                  {Math.round((lang.size / totalSize) * 100)}%
                </span>
              </div>
            ))}
          </div>
        </>
      )
    }
  </div>
</section>

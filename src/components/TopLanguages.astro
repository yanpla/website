---
export const prerender = false;

interface Language {
  name: string;
  color: string;
  size: number;
}

interface Repo {
  name: string;
  fork: boolean;
  languages_url: string;
}

const username = "yanpla";
const CACHE_TTL = 60 * 60 * 1000; // 1 hour

// Module-level cache so we stay well under GitHub's 60 req/hour anonymous limit
const globalCache = globalThis as typeof globalThis & {
  __topLangsCache?: { data: Language[]; fetchedAt: number };
};

let sortedLangs: Language[] = [];
let totalSize = 0;
let error: string | null = null;

const cached = globalCache.__topLangsCache;
if (cached && Date.now() - cached.fetchedAt < CACHE_TTL) {
  sortedLangs = cached.data;
} else {
  try {
    // Colors come from GitHub's public linguist data
    const colorsResponse = await fetch(
      "https://raw.githubusercontent.com/ozh/github-colors/master/colors.json",
    );
    const colors: Record<string, { color: string | null }> = colorsResponse.ok
      ? await colorsResponse.json()
      : {};

    const reposResponse = await fetch(
      `https://api.github.com/users/${username}/repos?per_page=100&type=owner`,
      { headers: { Accept: "application/vnd.github+json" } },
    );

    if (!reposResponse.ok) {
      throw new Error(`HTTP error! status: ${reposResponse.status}`);
    }

    const excludeList = ["remnantsoflight"];
    const repos = ((await reposResponse.json()) as Repo[]).filter(
      (repo) => !repo.fork && !excludeList.includes(repo.name),
    );

    const languageResults = await Promise.all(
      repos.map(async (repo) => {
        const res = await fetch(repo.languages_url, {
          headers: { Accept: "application/vnd.github+json" },
        });
        if (!res.ok) return {};
        return (await res.json()) as Record<string, number>;
      }),
    );

    const langMap = languageResults.reduce<Record<string, Language>>(
      (acc, langs) => {
        for (const [name, size] of Object.entries(langs)) {
          if (!acc[name]) {
            acc[name] = {
              name,
              color: colors[name]?.color ?? "#8b8b8b",
              size: 0,
            };
          }
          acc[name].size += size;
        }
        return acc;
      },
      {},
    );

    sortedLangs = Object.values(langMap)
      .sort((a, b) => b.size - a.size)
      .slice(0, 6);

    globalCache.__topLangsCache = { data: sortedLangs, fetchedAt: Date.now() };
  } catch (e) {
    error = e instanceof Error ? e.message : "Failed to fetch languages";
  }
}

totalSize = sortedLangs.reduce((acc, curr) => acc + curr.size, 0);
---

<section>
  <div class="flex flex-col space-y-5">
    <div class="flex justify-between items-baseline">
      <h2 class="text-2xl font-bold tracking-tight">top languages</h2>
      <span class="text-xs text-muted-foreground font-mono tracking-wide">based on github bytes</span>
    </div>

    {
      error ? (
        <div class="text-sm text-muted-foreground animate-entrance">failed to load: {error}</div>
      ) : sortedLangs.length === 0 ? (
        <div class="text-sm text-muted-foreground animate-entrance">no languages found</div>
      ) : (
        <>
          {/* Progress Bar */}
          <div class="flex w-full h-2.5 overflow-hidden rounded-full bg-muted">
            <div class="flex w-full h-full animate-bar-fill">
              {sortedLangs.map((lang) => (
                <div
                  style={{
                    width: `${(lang.size / totalSize) * 100}%`,
                    backgroundColor: lang.color,
                  }}
                  class="h-full transition-opacity duration-200 hover:opacity-75"
                  title={`${lang.name} ${Math.round((lang.size / totalSize) * 100)}%`}
                />
              ))}
            </div>
          </div>

          {/* Legend */}
          <div class="grid grid-cols-2 md:grid-cols-3 gap-y-2.5 gap-x-4">
            {sortedLangs.map((lang, i) => (
              <div
                class="flex items-center space-x-2 animate-entrance"
                style={`animation-delay: ${0.1 + i * 0.05}s;`}
              >
                <div
                  class="w-2.5 h-2.5 rounded-full flex-shrink-0"
                  style={{ backgroundColor: lang.color }}
                />
                <span class="text-sm font-medium truncate">{lang.name}</span>
                <span class="text-xs text-muted-foreground tabular-nums">
                  {Math.round((lang.size / totalSize) * 100)}%
                </span>
              </div>
            ))}
          </div>
        </>
      )
    }
  </div>
</section>

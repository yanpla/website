---
export const prerender = false;

interface Language {
  name: string;
  color: string;
  size: number;
}

const GITHUB_TOKEN = import.meta.env.GITHUB_TOKEN;
const username = "yanpla";

let sortedLangs: Language[] = [];
let totalSize = 0;
let error: string | null = null;

if (!GITHUB_TOKEN) {
  error = "GitHub token not configured";
} else {
  try {
    const query = `
      query userInfo($login: String!) {
        user(login: $login) {
          repositories(ownerAffiliations: [OWNER, COLLABORATOR], isFork: false, first: 100, privacy: PUBLIC) {
            nodes {
              name
              languages(first: 10, orderBy: {field: SIZE, direction: DESC}) {
                edges {
                  size
                  node {
                    color
                    name
                  }
                }
              }
            }
          }
        }
      }
    `;

    const response = await fetch("https://api.github.com/graphql", {
      method: "POST",
      headers: {
        Authorization: `Bearer ${GITHUB_TOKEN}`,
        "Content-Type": "application/json",
      },
      body: JSON.stringify({ query, variables: { login: username } }),
    });

    if (!response.ok) {
      throw new Error(`HTTP error! status: ${response.status}`);
    }

    const json = await response.json();

    if (json.errors) {
      throw new Error(json.errors[0]?.message || "GraphQL error");
    }

    const excludeList = ["remnantsoflight"];
    const repos = json.data?.user?.repositories?.nodes?.filter(
      (repo: any) => !excludeList.includes(repo.name),
    ) || [];

    const langMap = repos
      .filter((repo: any) => repo.languages?.edges?.length > 0)
      .reduce((acc: Record<string, Language>, repo: any) => {
        repo.languages.edges.forEach((edge: any) => {
          const { name, color } = edge.node;
          if (!acc[name]) {
            acc[name] = { name, color, size: 0 };
          }
          acc[name].size += edge.size;
        });
        return acc;
      }, {});

    sortedLangs = (Object.values(langMap) as Language[])
      .sort((a, b) => b.size - a.size)
      .slice(0, 6);

    totalSize = sortedLangs.reduce((acc, curr) => acc + curr.size, 0);
  } catch (e) {
    error = e instanceof Error ? e.message : "Failed to fetch languages";
  }
}
---

<section>
  <div class="flex flex-col space-y-4">
    <div class="flex justify-between items-end">
      <h2 class="text-2xl font-bold">top languages</h2>
      <span class="text-xs opacity-50 font-mono">based on github bytes</span>
    </div>

    {error ? (
      <div class="text-sm text-red-400 opacity-75">
        failed to load: {error}
      </div>
    ) : sortedLangs.length === 0 ? (
      <div class="text-sm opacity-50">no languages found</div>
    ) : (
      <>
        {/* The Progress Bar */}
        <div class="flex w-full h-3 overflow-hidden rounded-full bg-neutral-800">
          {sortedLangs.map((lang) => (
            <div
              style={{
                width: `${(lang.size / totalSize) * 100}%`,
                backgroundColor: lang.color,
              }}
              class="h-full hover:opacity-80 transition-opacity"
              title={`${lang.name} ${Math.round((lang.size / totalSize) * 100)}%`}
            />
          ))}
        </div>

        {/* The Legend */}
        <div class="grid grid-cols-2 md:grid-cols-3 gap-y-2 gap-x-4">
          {sortedLangs.map((lang) => (
            <div class="flex items-center space-x-2">
              <div
                class="w-3 h-3 rounded-full"
                style={{ backgroundColor: lang.color }}
              />
              <span class="text-sm font-medium">{lang.name}</span>
              <span class="text-xs opacity-50">
                {Math.round((lang.size / totalSize) * 100)}%
              </span>
            </div>
          ))}
        </div>
      </>
    )}
  </div>
</section>

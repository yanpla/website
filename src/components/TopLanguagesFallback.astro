---
---

<section>
  <div class="flex flex-col space-y-5">
    {/* Visible header */}
    <div class="flex justify-between items-baseline animate-entrance animate-entrance-3">
      <h2 class="text-2xl font-bold tracking-tight">top languages</h2>
      <span class="text-xs text-muted-foreground font-mono tracking-wide">based on github bytes</span>
    </div>

    {/* Invisible spacer for the bar + legend so layout doesn't shift */}
    <div class="invisible">
      <div class="flex flex-col space-y-5">
        <div class="w-full h-2.5"></div>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-y-2.5 gap-x-4">
          {
            Array.from({ length: 6 }).map(() => (
              <div class="flex items-center space-x-2">
                <div class="w-2.5 h-2.5" />
                <span class="text-sm">&nbsp;</span>
                <span class="text-xs">&nbsp;</span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

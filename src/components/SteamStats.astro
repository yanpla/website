---
export const prerender = false;

interface OwnedGame {
  appid: number;
  name: string;
  playtime_forever: number; // minutes
  playtime_2weeks?: number; // minutes
  img_icon_url: string;
}

interface SteamStats {
  personaName: string;
  personaState: number;
  gameCount: number;
  totalMinutes: number;
  recentMinutes: number;
  topGames: { name: string; hours: number; icon: string }[];
}

const vanityName = "yanpla";

// Free key from https://steamcommunity.com/dev/apikey
const STEAM_API_KEY =
  import.meta.env.STEAM_API_KEY ?? process.env.STEAM_API_KEY;

const CACHE_TTL = 60 * 60 * 1000; // 1 hour
const globalCache = globalThis as typeof globalThis & {
  __steamStatsCache?: { data: SteamStats; fetchedAt: number };
};

const steamFetch = async <T,>(
  iface: string,
  method: string,
  version: string,
  params: Record<string, string>,
): Promise<T> => {
  const query = new URLSearchParams({ key: STEAM_API_KEY ?? "", ...params });
  const res = await fetch(
    `https://api.steampowered.com/${iface}/${method}/${version}/?${query}`,
  );
  if (!res.ok) throw new Error(`HTTP error! status: ${res.status}`);
  return (await res.json()) as T;
};

const fetchSteamStats = async (): Promise<SteamStats> => {
  const vanity = await steamFetch<{
    response: { steamid?: string; success: number };
  }>("ISteamUser", "ResolveVanityURL", "v1", { vanityurl: vanityName });
  const steamid = vanity.response.steamid;
  if (!steamid) throw new Error("Could not resolve Steam vanity URL");

  const [summaries, owned] = await Promise.all([
    steamFetch<{
      response: { players: { personaname: string; personastate: number }[] };
    }>("ISteamUser", "GetPlayerSummaries", "v2", { steamids: steamid }),
    steamFetch<{
      response: { game_count: number; games?: OwnedGame[] };
    }>("IPlayerService", "GetOwnedGames", "v1", {
      steamid,
      include_appinfo: "1",
      include_played_free_games: "1",
    }),
  ]);

  const player = summaries.response.players[0];
  const games = owned.response.games ?? [];

  return {
    personaName: player?.personaname ?? vanityName,
    personaState: player?.personastate ?? 0,
    gameCount: owned.response.game_count,
    totalMinutes: games.reduce((acc, g) => acc + g.playtime_forever, 0),
    recentMinutes: games.reduce((acc, g) => acc + (g.playtime_2weeks ?? 0), 0),
    topGames: [...games]
      .sort((a, b) => b.playtime_forever - a.playtime_forever)
      .slice(0, 3)
      .map((g) => ({
        name: g.name,
        hours: Math.round(g.playtime_forever / 60),
        icon: g.img_icon_url
          ? `https://media.steampowered.com/steamcommunity/public/images/apps/${g.appid}/${g.img_icon_url}.jpg`
          : "",
      })),
  };
};

let stats: SteamStats | null = null;
let error: string | null = null;

const cached = globalCache.__steamStatsCache;
if (!STEAM_API_KEY) {
  error = "Steam API key not configured";
} else if (cached && Date.now() - cached.fetchedAt < CACHE_TTL) {
  stats = cached.data;
} else {
  try {
    stats = await fetchSteamStats();
    globalCache.__steamStatsCache = { data: stats, fetchedAt: Date.now() };
  } catch (e) {
    // Serve stale data rather than an error if a refresh fails
    if (cached) {
      stats = cached.data;
    } else {
      error = e instanceof Error ? e.message : "Failed to fetch stats";
    }
  }
}

// Steam persona states: 0 offline, 1 online, 2 busy, 3 away, 4 snooze,
// 5 looking to trade, 6 looking to play
const stateNames = ["offline", "online", "busy", "away", "snooze", "trading", "playing"];
const stateColors = ["#80848e", "#57cbde", "#f23f43", "#f0b232", "#f0b232", "#57cbde", "#a3e26a"];
const personaState = stats?.personaState ?? 0;
const stateName = stateNames[personaState] ?? "offline";
const stateColor = stateColors[personaState] ?? stateColors[0];

const totalHours = stats ? Math.round(stats.totalMinutes / 60) : 0;
const recentHours = stats ? Math.round(stats.recentMinutes / 60) : 0;
const formatHours = (hours: number) =>
  hours >= 1000 ? `${(hours / 1000).toFixed(1)}k` : `${hours}`;
---

<section>
  <div class="flex flex-col space-y-5">
    <div class="flex justify-between items-baseline">
      <h2 class="text-2xl font-bold tracking-tight">steam</h2>
      <span class="text-xs text-muted-foreground font-mono tracking-wide">
        {stats?.personaName ?? vanityName} · {stats?.gameCount ?? "?"} games
      </span>
    </div>

    {
      error ? (
        <div class="text-sm text-muted-foreground animate-entrance">failed to load: {error}</div>
      ) : !stats ? (
        <div class="text-sm text-muted-foreground animate-entrance">no stats found</div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {/* Profile summary */}
          <div class="flex flex-col space-y-3 animate-entrance" style="animation-delay: 0.1s;">
            <div class="flex items-center justify-between">
              <div class="flex items-center space-x-2">
                <div
                  class="w-2.5 h-2.5 rounded-full flex-shrink-0"
                  style={{ backgroundColor: stateColor, boxShadow: `0 0 6px ${stateColor}` }}
                />
                <span class="text-sm font-medium">{stateName}</span>
              </div>
            </div>
            <div class="flex justify-between text-xs text-muted-foreground tabular-nums">
              <span>{formatHours(totalHours)} hours played</span>
              <span>{recentHours}h past 2 weeks</span>
            </div>
          </div>

          {/* Most-played games */}
          <div class="flex flex-col space-y-3">
            {stats.topGames.map((game, i) => (
              <div
                class="flex items-center space-x-3 animate-entrance"
                style={`animation-delay: ${0.15 + i * 0.05}s;`}
              >
                {game.icon && (
                  <img
                    src={game.icon}
                    alt={game.name}
                    class="w-6 h-6 rounded-full flex-shrink-0"
                    loading="lazy"
                  />
                )}
                <span class="text-sm font-medium truncate">{game.name}</span>
                <span class="text-xs text-muted-foreground tabular-nums ml-auto">
                  {formatHours(game.hours)} hrs
                </span>
              </div>
            ))}
          </div>
        </div>
      )
    }
  </div>
</section>

---
export const prerender = false;

interface RankedEntry {
  queueType: string;
  tier: string;
  rank: string;
  leaguePoints: number;
  wins: number;
  losses: number;
}

interface ChampionMastery {
  championId: number;
  championLevel: number;
  championPoints: number;
}

interface LeagueStats {
  summonerLevel: number;
  solo: RankedEntry | null;
  flex: RankedEntry | null;
  topChamps: { name: string; level: number; points: number; icon: string }[];
}

const gameName = "yanpla";
const tagLine = "EUW";
const platform = "euw1"; // platform routing (summoner/league/mastery)
const region = "europe"; // regional routing (account-v1)

// Development API keys from developer.riotgames.com expire every 24h;
// a personal/production key does not
const RIOT_API_KEY =
  import.meta.env.RIOT_API_KEY ?? process.env.RIOT_API_KEY;
const riotHeaders = { "X-Riot-Token": RIOT_API_KEY ?? "" };

const CACHE_TTL = 60 * 60 * 1000; // 1 hour
const globalCache = globalThis as typeof globalThis & {
  __leagueStatsCache?: { data: LeagueStats; fetchedAt: number };
};

const riotFetch = async <T,>(url: string): Promise<T> => {
  const res = await fetch(url, { headers: riotHeaders });
  if (!res.ok) throw new Error(`HTTP error! status: ${res.status}`);
  return (await res.json()) as T;
};

const fetchLeagueStats = async (): Promise<LeagueStats> => {
  const { puuid } = await riotFetch<{ puuid: string }>(
    `https://${region}.api.riotgames.com/riot/account/v1/accounts/by-riot-id/${gameName}/${tagLine}`,
  );

  // Champion names/icons come from the public Data Dragon CDN (no key needed)
  const [versions, summoner, entries, masteries] = await Promise.all([
    riotFetch<string[]>("https://ddragon.leagueoflegends.com/api/versions.json"),
    riotFetch<{ summonerLevel: number }>(
      `https://${platform}.api.riotgames.com/lol/summoner/v4/summoners/by-puuid/${puuid}`,
    ),
    riotFetch<RankedEntry[]>(
      `https://${platform}.api.riotgames.com/lol/league/v4/entries/by-puuid/${puuid}`,
    ),
    riotFetch<ChampionMastery[]>(
      `https://${platform}.api.riotgames.com/lol/champion-mastery/v4/champion-masteries/by-puuid/${puuid}/top?count=3`,
    ),
  ]);

  const ddVersion = versions[0];
  const championData = await riotFetch<{
    data: Record<string, { key: string; name: string; id: string }>;
  }>(
    `https://ddragon.leagueoflegends.com/cdn/${ddVersion}/data/en_US/champion.json`,
  );
  const champById = new Map(
    Object.values(championData.data).map((c) => [c.key, c]),
  );

  return {
    summonerLevel: summoner.summonerLevel,
    solo: entries.find((e) => e.queueType === "RANKED_SOLO_5x5") ?? null,
    flex: entries.find((e) => e.queueType === "RANKED_FLEX_SR") ?? null,
    topChamps: masteries.map((m) => {
      const champ = champById.get(String(m.championId));
      return {
        name: champ?.name ?? `Champion ${m.championId}`,
        level: m.championLevel,
        points: m.championPoints,
        icon: champ
          ? `https://ddragon.leagueoflegends.com/cdn/${ddVersion}/img/champion/${champ.id}.png`
          : "",
      };
    }),
  };
};

let stats: LeagueStats | null = null;
let error: string | null = null;

const cached = globalCache.__leagueStatsCache;
if (!RIOT_API_KEY) {
  error = "Riot API key not configured";
} else if (cached && Date.now() - cached.fetchedAt < CACHE_TTL) {
  stats = cached.data;
} else {
  try {
    stats = await fetchLeagueStats();
    globalCache.__leagueStatsCache = { data: stats, fetchedAt: Date.now() };
  } catch (e) {
    // Serve stale data rather than an error if a refresh fails
    if (cached) {
      stats = cached.data;
    } else {
      error = e instanceof Error ? e.message : "Failed to fetch stats";
    }
  }
}

const tierColors: Record<string, string> = {
  IRON: "#8e8583",
  BRONZE: "#a9744f",
  SILVER: "#a5b3c2",
  GOLD: "#e8b64d",
  PLATINUM: "#4fc4b0",
  EMERALD: "#2ec46f",
  DIAMOND: "#5e9fe6",
  MASTER: "#b04ee6",
  GRANDMASTER: "#e04848",
  CHALLENGER: "#3fd0f0",
};

const solo = stats?.solo ?? null;
const totalGames = solo ? solo.wins + solo.losses : 0;
const winrate = totalGames ? Math.round((solo!.wins / totalGames) * 100) : 0;
const tierColor = solo ? (tierColors[solo.tier] ?? "#8b8b8b") : "#8b8b8b";
const tierDisplay = solo
  ? `${solo.tier.charAt(0) + solo.tier.slice(1).toLowerCase()} ${solo.rank}`
  : "Unranked";

const formatPoints = (points: number) =>
  points >= 1000 ? `${Math.round(points / 1000)}k` : `${points}`;
---

<section>
  <div class="flex flex-col space-y-5">
    <div class="flex justify-between items-baseline">
      <h2 class="text-2xl font-bold tracking-tight">league of legends</h2>
      <span class="text-xs text-muted-foreground font-mono tracking-wide">
        {gameName}#{tagLine} · lvl {stats?.summonerLevel ?? "?"}
      </span>
    </div>

    {
      error ? (
        <div class="text-sm text-muted-foreground animate-entrance">failed to load: {error}</div>
      ) : !stats ? (
        <div class="text-sm text-muted-foreground animate-entrance">no stats found</div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {/* Ranked solo/duo */}
          <div class="flex flex-col space-y-3 animate-entrance" style="animation-delay: 0.1s;">
            <div class="flex items-center justify-between">
              <div class="flex items-center space-x-2">
                <div
                  class="w-2.5 h-2.5 rounded-full flex-shrink-0"
                  style={{ backgroundColor: tierColor, boxShadow: `0 0 6px ${tierColor}` }}
                />
                <span class="text-sm font-medium">{tierDisplay}</span>
                {solo && (
                  <span class="text-xs text-muted-foreground tabular-nums">{solo.leaguePoints} lp</span>
                )}
              </div>
              <span class="text-xs text-muted-foreground font-mono tracking-wide">ranked solo/duo</span>
            </div>

            {solo && (
              <>
                <div class="flex w-full h-2.5 overflow-hidden rounded-full bg-muted" title={`${winrate}% winrate`}>
                  <div
                    class="h-full transition-opacity duration-200 hover:opacity-75 rounded-full"
                    style={{ width: `${winrate}%`, backgroundColor: tierColor }}
                  />
                </div>
                <div class="flex justify-between text-xs text-muted-foreground tabular-nums">
                  <span>{solo.wins}w / {solo.losses}l</span>
                  <span>{winrate}% winrate</span>
                </div>
              </>
            )}
          </div>

          {/* Top champion masteries */}
          <div class="flex flex-col space-y-3">
            {stats.topChamps.map((champ, i) => (
              <div
                class="flex items-center space-x-3 animate-entrance"
                style={`animation-delay: ${0.15 + i * 0.05}s;`}
              >
                {champ.icon && (
                  <img
                    src={champ.icon}
                    alt={champ.name}
                    class="w-6 h-6 rounded-full flex-shrink-0"
                    loading="lazy"
                  />
                )}
                <span class="text-sm font-medium truncate">{champ.name}</span>
                <span class="text-xs text-muted-foreground tabular-nums ml-auto">
                  mastery {champ.level} · {formatPoints(champ.points)} pts
                </span>
              </div>
            ))}
          </div>
        </div>
      )
    }
  </div>
</section>

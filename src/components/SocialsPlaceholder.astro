---
import SocialCard from "./SocialCard.astro";
import DiscordIcon from "../assets/discord.svg";
import GithubIcon from "../assets/github.svg";

const username = "yanpla";
const userId = "287291530685841409";
---

<div
  class="flex flex-col-reverse md:flex-row-reverse md:justify-normal items-center"
>
  <SocialCard
    href={`https://discord.com/users/${userId}`}
    title="Discord"
    subtitle="@yanpla"
  >
    <DiscordIcon slot="icon" />
  </SocialCard>

  <SocialCard
    href={`https://github.com/${username}`}
    title="GitHub"
    subtitle="@yanpla"
  >
    <GithubIcon slot="icon" />
  </SocialCard>
</div>

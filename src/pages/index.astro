---
import Hero from "../components/Hero.astro";
import Layout from "../layouts/Layout.astro";
import Socials from "../components/Socials.astro";
import TopLanguages from "../components/TopLanguages.astro";
import SocialsFallback from "../components/SocialsFallback.astro";
import TopLanguagesFallback from "../components/TopLanguagesFallback.astro";
import LeagueStats from "../components/LeagueStats.astro";
import LeagueStatsFallback from "../components/LeagueStatsFallback.astro";
---

<Layout>
  <main
    class="flex flex-col items-center justify-center min-h-screen w-full px-6 md:px-[12%] lg:px-[16%] py-20"
  >
    <div class="flex flex-col space-y-16 w-full max-w-4xl">
      <div class="w-full animate-entrance animate-entrance-1">
        <Hero />
      </div>
      <div class="w-full animate-entrance animate-entrance-2">
        <Socials server:defer>
          <SocialsFallback slot="fallback" />
        </Socials>
      </div>
      <div class="w-full">
        <TopLanguages server:defer>
          <TopLanguagesFallback slot="fallback" />
        </TopLanguages>
      </div>
      {/* Easter egg: hidden until the visitor clicks the hero avatar (click again to hide) */}
      <div class="w-full hidden" id="league-stats">
        <LeagueStats server:defer>
          <LeagueStatsFallback slot="fallback" />
        </LeagueStats>
      </div>
    </div>
  </main>

  <script>
    const league = document.getElementById("league-stats");
    const setVisible = (visible: boolean) => {
      league?.classList.toggle("hidden", !visible);
      localStorage.setItem("gg", visible ? "1" : "");
    };
    if (localStorage.getItem("gg")) setVisible(true);

    document.getElementById("hero-pfp")?.addEventListener("click", () => {
      setVisible(league?.classList.contains("hidden") ?? false);
    });
  </script>
</Layout>
